# Optional. When absent, the project uses deterministic local embeddings and an extractive answerer.
OPENAI_API_KEY=

# Optional model choices when OPENAI_API_KEY is set.
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini

# Retrieval/grounding knobs.
RAG_MIN_SIMILARITY=0.18
RAG_TOP_K=5

